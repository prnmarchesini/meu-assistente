# Modelo de variaveis de ambiente do Back.
# Copie este arquivo para ".env" e preencha com os valores reais.
# (o .env real NAO sobe para o GitHub)

# --- Banco de dados (Supabase) ---
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:6543/postgres
DIRECT_URL=postgresql://USUARIO:SENHA@HOST:5432/postgres

# --- Chaves de IA ---
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# --- Porta ---
PORT=3000
