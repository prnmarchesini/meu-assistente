# Modelo de variaveis de ambiente do backend.
# Copie para ".env" e preencha. O .env real NAO sobe para o GitHub.

# ── Supabase: API / Auth / Storage ──
# Painel Supabase > Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Supabase: conexoes Postgres ──
# Painel Supabase > Connect. A senha com '#' pode ser usada literal.
# Transaction pooler (6543) e session pooler (5432).
SUPABASE_TRANSACTION_URL=postgresql://postgres.PROJ:SENHA@HOST:6543/postgres
SUPABASE_POOLER_URL=postgresql://postgres.PROJ:SENHA@HOST:5432/postgres

# ── IA ──
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── Telegram (Passo 6) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── Infra ──
RAILWAY_TOKEN=

# ── Local ──
PORT=8000
